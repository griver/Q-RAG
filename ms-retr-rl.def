Bootstrap: docker
From: debian:bookworm-slim

%files
    # Copy requirements.txt from host to container (build time)
    ./requirements.txt /opt/requirements.txt

%post
    apt-get update && apt-get upgrade -y

    apt-get update && apt-get install -y \
    build-essential cmake \
    python3 python3-dev python3-pip \
    libssl-dev libffi-dev zlib1g-dev libjpeg-dev \
    libopenblas-dev liblapack-dev \
    wget curl vim less

    pip install --no-cache-dir --break-system-packages -r /opt/requirements.txt

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C

%runscript
    python --version

%help
    This container provides:



# apptainer build --fakeroot --disable-cache ./ms-retr-rl.sif ./ms-retr-rl.def
